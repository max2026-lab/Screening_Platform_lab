{
  "primary": "earth_search",
  "fallbacks": [
    "cdse",
    "landsatlook"
  ],
  "earth_search": {
    "provider": "earth-search",
    "role": "primary",
    "synchronous_only": true,
    "active": false,
    "base_url": "https://earth-search.aws.element84.com/v1",
    "search_path": "search",
    "collections": [
      "sentinel-2-l2a"
    ],
    "timeout_seconds": 30,
    "max_items": 10,
    "metadata_only": true
  },
  "cdse": {
    "provider": "cdse",
    "role": "fallback",
    "synchronous_only": true
  },
  "landsatlook": {
    "provider": "landsatlook",
    "role": "fallback",
    "synchronous_only": true
  }
}
